# PostHog self-hosted (template HASHING3) — referência de variáveis de ambiente
# ───────────────────────────────────────────────────────────────────────────
# Este arquivo é REFERÊNCIA para compor o template na Railway. Ele NÃO é
# consumido pelo build das imagens (o build só usa POSTHOG_APP_TAG, no
# workflow). As variáveis de runtime são configuradas por serviço na Railway.
#
# Nível de confiança de cada bloco:
#   [VERIFICADO]   conferido na fonte primária (Dockerfiles/scripts deste repo
#                  ou registry). Pode cravar.
#   [A-CONFIRMAR]  nome/obrigatoriedade conhecidos de forma geral, mas a lista
#                  autoritativa é o source do PostHog @ commit-âncora e a
#                  definição do template na Railway. Confirmar antes de cravar
#                  (anti-pattern premissa-de-fonte-secundaria-nao-verificada).
#
# NUNCA commitar segredos reais aqui — só placeholders.

# ═══════════════════════════════════════════════════════════════════════════
# OBJECT STORAGE — 100% Backblaze B2  [VERIFICADO]  (ADR-015)
# ───────────────────────────────────────────────────────────────────────────
# Substitui SeaweedFS + MinIO do template-base. Duas famílias de variáveis,
# ambas apontando para o B2 (S3-compatible):
#   OBJECT_STORAGE_*            -> exports, query cache, uploads (web/worker/plugins)
#   SESSION_RECORDING_V2_S3_*   -> gravações de Session Replay (ATIVO, web/worker)
# O cymbal (error tracking) usa OBJECT_STORAGE_ENDPOINT.
#
# B2: criar 1 Application Key com acesso ao(s) bucket(s). region/endpoint vêm
# do painel B2 (ex.: s3.us-west-004.backblazeb2.com).

OBJECT_STORAGE_ENABLED=true
OBJECT_STORAGE_ENDPOINT=https://s3.<region>.backblazeb2.com
OBJECT_STORAGE_REGION=<region>                     # ex.: us-west-004
OBJECT_STORAGE_ACCESS_KEY_ID=<b2_application_key_id>
OBJECT_STORAGE_SECRET_ACCESS_KEY=<b2_application_key>
OBJECT_STORAGE_BUCKET=<posthog-bucket>

SESSION_RECORDING_V2_S3_ENDPOINT=https://s3.<region>.backblazeb2.com
SESSION_RECORDING_V2_S3_REGION=<region>
SESSION_RECORDING_V2_S3_ACCESS_KEY_ID=<b2_application_key_id>
SESSION_RECORDING_V2_S3_SECRET_ACCESS_KEY=<b2_application_key>
SESSION_RECORDING_V2_S3_BUCKET=<posthog-bucket>
# Opcional: prefixo de pastas dentro do bucket, se separar replay dos exports.
# SESSION_RECORDING_V2_S3_PREFIX=session_recordings

# ═══════════════════════════════════════════════════════════════════════════
# WIRING ENTRE SERVIÇOS  [VERIFICADO — hostnames lidos dos Dockerfiles/scripts]
# ───────────────────────────────────────────────────────────────────────────
# Os hostnames são os nomes dos serviços na rede privada da Railway. Confirmar
# que os nomes de serviço batem com estes ao compor o template.
#   clickhouse:9000   (compose/wait)
#   db:5432           (compose/wait, postgres)
#   kafka:9092        (kafka-init KAFKA_HOSTS default)
KAFKA_HOSTS=kafka:9092
# REDIS_URL=redis://redis7:6379/        # serviço redis7 deste template
# DATABASE_URL=postgres://posthog:<pwd>@db:5432/posthog
# CLICKHOUSE_HOST=clickhouse

# ═══════════════════════════════════════════════════════════════════════════
# CORE POSTHOG / DJANGO  [A-CONFIRMAR no source @ commit-âncora]
# ───────────────────────────────────────────────────────────────────────────
# Lista mínima conhecida; NÃO assumir como completa. Conferir os obrigatórios
# no PostHog @ 9373a2b55081d3e711ad58bca060a6a9ab5d41a5 e na definição do
# template na Railway antes de subir.
SECRET_KEY=<gerar: openssl rand -hex 32>
ENCRYPTION_SALT_KEYS=<gerar: openssl rand -hex 16>
SITE_URL=https://<seu-dominio>
DISABLE_SECURE_SSL_REDIRECT=false
TRUST_ALL_PROXIES=true

# ═══════════════════════════════════════════════════════════════════════════
# PROXY (Caddy)  [VERIFICADO — proxy.Dockerfile lê CADDYFILE do ambiente]
# ───────────────────────────────────────────────────────────────────────────
# CADDYFILE=<conteúdo do Caddyfile>     # injetado como env pelo entrypoint
# CADDY_EXTRA_CONFIG=
